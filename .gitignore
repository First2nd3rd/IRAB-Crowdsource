# dependencies
node_modules/

# deployment / infrastructure — keep VPS host, port, user, and paths
# out of this repo
DEPLOY.md
DATA_EXPORT.md
ecosystem.config.cjs
scripts/deploy-to-vps.sh
scripts/pull-data.sh

# task data + collected feedback — generated by the pipeline / runtime,
# not committed. See README for the extract -> summarize -> localize flow.
data/*
!data/.gitkeep
exports/

# localized agent deliverables (images, attachments) — generated by extract
public/report-assets/*
!public/report-assets/.gitkeep

# os / editor cruft
.DS_Store
